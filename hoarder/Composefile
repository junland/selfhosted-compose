services:
  hoarder:
    image: 'ghcr.io/karakeep-app/karakeep:${SELFHOSTED_HOARDER_VERSION:-release}'
    container_name: hoarder-app-service
    hostname: 'hoarder'
    restart: unless-stopped
    environment:
      TZ: ${SELFHOSTED_TZ}
      BROWSER_WEB_URL: ${SELFHOSTED_HOARDER_BROWSER_WEB_URL}
      CRAWLER_NUM_WORKERS: ${SELFHOSTED_HOARDER_CRAWLER_NUM_WORKERS}
      CRAWLER_VIDEO_DOWNLOAD: ${SELFHOSTED_HOARDER_CRAWLER_VIDEO_DOWNLOAD}
      CRAWLER_VIDEO_DOWNLOAD_MAX_SIZE: ${SELFHOSTED_HOARDER_CRAWLER_VIDEO_DOWNLOAD_MAX_SIZE}
      DATA_DIR: ${SELFHOSTED_HOARDER_DATA_DIR}
      DISABLE_SIGNUPS: ${SELFHOSTED_HOARDER_DISABLE_SIGNUPS}
      INFERENCE_JOB_TIMEOUT_SEC: ${SELFHOSTED_HOARDER_INFERENCE_JOB_TIMEOUT_SEC}
      INFERENCE_TEXT_MODEL: ${SELFHOSTED_HOARDER_INFERENCE_TEXT_MODEL}
      MEILI_ADDR: ${SELFHOSTED_HOARDER_MEILI_ADDR}
      MEILI_MASTER_KEY: ${SELFHOSTED_HOARDER_MEILI_MASTER_KEY}
      NEXTAUTH_SECRET: ${SELFHOSTED_HOARDER_NEXTAUTH_SECRET}
      NEXTAUTH_URL: ${SELFHOSTED_HOARDER_NEXTAUTH_URL}
      NODE_NO_WARNINGS: ${SELFHOSTED_HOARDER_NODE_NO_WARNINGS}
      OLLAMA_BASE_URL: ${SELFHOSTED_HOARDER_OLLAMA_BASE_URL}
      OLLAMA_KEEP_ALIVE: ${SELFHOSTED_HOARDER_OLLAMA_KEEP_ALIVE}
    volumes:
      - hoarder_app_data:/data

  chrome:
    build:
      context: .
      dockerfile: Containerfile.chrome
    image: 'localhost/alpine-chrome:adblock'
    container_name: 'hoarder-chrome-service'
    hostname: 'chrome'
    restart: unless-stopped
    environment:
      TZ: ${SELFHOSTED_TZ}
    command:
      - --disable-dev-shm-usage
      - --disable-gpu
      - --disable-sync
      - --hide-scrollbars
      - --load-extension=/usr/src/app/extensions/adblock
      - --no-first-run
      - --no-sandbox
      - --remote-debugging-address=0.0.0.0
      - --remote-debugging-port=9222

  meilisearch:
    image: 'docker.io/getmeili/meilisearch:v1.13'
    container_name: 'hoarder-search-service'
    hostname: 'meilisearch'
    restart: unless-stopped
    environment:
      TZ: ${SELFHOSTED_TZ}
      MEILI_MASTER_KEY: ${SELFHOSTED_HOARDER_MEILI_MASTER_KEY}
      MEILI_NO_ANALYTICS: ${SELFHOSTED_HOARDER_MEILI_NO_ANALYTICS}
    volumes:
      - hoarder_search_data:/meili_data

volumes:
  hoarder_app_data:
    name: 'hoarder_app_data'
    labels:
      backup: "true"
  hoarder_search_data:
    name: 'hoarder_search_data'
    labels:
      backup: "true"
