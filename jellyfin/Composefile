services:
  jellyfin:
    build:
      context: .
      dockerfile: Containerfile
    image: 'localhost/jellyfin:latest'
    container_name: jellyfin-app-service
    hostname: 'jellyfin'
    restart: unless-stopped
    environment:
      TZ: ${SELFHOSTED_TZ}
      JELLYFIN_PublishedServerUrl: ${SELFHOSTED_JELLYFIN_PUBLISHED_SERVICE_URL}
    volumes:
      - '$SELFHOSTED_JELLYFIN_PRIMARY_MEDIA_HOST_DIR:/media/primary'
      - '$SELFHOSTED_JELLYFIN_SECONDARY_MEDIA_HOST_DIR:/media/secondary'
      - 'jellyfin_cache_data:/cache'
      - 'jellyfin_data:/config'
    devices:
      - nvidia.com/gpu=all  
    healthcheck:
      test: curl --fail http://localhost:8096/health || exit 1
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 120s
    labels:
      - "io.containers.autoupdate=registry"
      - "com.infra.service=jellyfin"

volumes:
  jellyfin_data:
    name: 'jellyfin_app_data'
    labels:
      backup: 'true'
  jellyfin_cache_data:
    name: 'jellyfin_cache_data'
    labels:
      backup: 'true'
