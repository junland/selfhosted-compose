services:
  jenkins:
    image: 'docker.io/jenkins/jenkins:latest-jdk25'
    container_name: jenkins-app-service
    hostname: 'jenkins'
    restart: always
    privileged: true
    tty: true
    group_add:
      - 1001
    volumes:
      - ci_app_data:/var/jenkins_home
      - /var/run/podman/podman.sock:/var/run/docker.sock
      - /etc/localtime:/etc/localtime:ro
    environment:
      JAVA_OPTS: -Xms4G -Xmx8G -XX:MaxMetaspaceSize=512m -XX:+UseStringDeduplication -XX:+UseParallelGC -XX:+AlwaysPreTouch
      DOCKER_HOST: unix:///var/run/docker.sock
      TZ: US/Central
    healthcheck:
      test: curl -sfL http://localhost:8080/health || exit 1
      interval: 30s
      timeout: 30s
      retries: 8
      start_period: 120s
    labels:
      - "io.containers.autoupdate=registry"
      - "com.infra.service=ci"
    cap_add:
      - SYS_CHROOT
    deploy:
      resources:
        limits:
          cpus: 8
        reservations:
          cpus: 4

  agent:
    build:
      context: .
      dockerfile: images/Containerfile.agent
    image: 'localhost/jenkins-agent:latest'
    container_name: jenkins-agent-service
    hostname: 'jenkins-agent'
    restart: always
    privileged: true
    user: root
    tty: true
    devices:
      - "/dev/tty:/dev/tty"
    expose:
      - 22
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /etc/localtime:/etc/localtime:ro
    environment:
      JAVA_OPTS: -Xms2G -Xmx4G -XX:MaxMetaspaceSize=512m -XX:+UseStringDeduplication -XX:+UseParallelGC -XX:+AlwaysPreTouch
      JENKINS_AGENT_SSH_PUBKEY: selfhosted_ci_agent_pubkey
      TZ: US/Central
    labels:
      - "io.containers.autoupdate=registry"
      - "com.infra.service=ci"
    cap_add:
      - SYS_CHROOT
    deploy:
      resources:
        limits:
          cpus: 10
        reservations:
          cpus: 10

volumes:
  ci_app_data:
    name: ci_app_data
    labels:
      backup: 'true'
