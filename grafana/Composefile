services:
  grafana:
    image: 'docker.io/grafana/grafana:12.4'
    container_name: grafana-app-service
    hostname: 'grafana'
    restart: unless-stopped
    volumes:
      - 'grafana_data:/var/lib/grafana'
    healthcheck:
      test: ["CMD-SHELL", "curl -sS http://localhost:3000/api/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    labels:
      - "com.infra.service=grafana"
      - "io.containers.autoupdate=registry"

volumes:
  grafana_data:
    name: "grafana_app_data"
    labels:
      backup: 'true'
