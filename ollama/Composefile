services:
  ollama:
    image: 'docker.io/ollama/ollama:latest'
    container_name: ollama-app-service
    hostname: 'ollama'
    restart: unless-stopped
    tty: true
    environment:
      OLLAMA_KEEP_ALIVE: ${SELFHOSTED_OLLAMA_KEEP_ALIVE}
      GIN_MODE: ${SELFHOSTED_OLLAMA_GIN_MODE}
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - /etc/timezone:/etc/timezone:ro
      - ollama_app_data:/root/.ollama
    devices:
      - nvidia.com/gpu=all  
    labels:
      - "io.containers.autoupdate=registry"
      - "com.infra.service=ollama"

volumes:
  ollama_app_data:
    name: ollama_app_data
    labels:
      backup: 'false'
