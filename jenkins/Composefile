services:
  jenkins:
    image: 'docker.io/jenkins/jenkins:latest-jdk25'
    container_name: jenkins-app-service
    hostname: 'jenkins'
    restart: always
    privileged: true
    tty: true
    group_add:
      - 1001
    volumes:
      - ci_app_data:/var/jenkins_home
      - /var/run/podman/podman.sock:/var/run/docker.sock
    environment:
      JAVA_OPTS: ${SELFHOSTED_JENKINS_JAVA_OPTS}
      DOCKER_HOST: ${SELFHOSTED_DOCKER_HOST}
      TZ: ${SELFHOSTED_TZ}
    healthcheck:
      test: curl -sfL http://localhost:8080/health || exit 1
      interval: 30s
      timeout: 30s
      retries: 8
      start_period: 120s
    labels:
      - "io.containers.autoupdate=registry"
      - "com.infra.service=ci"
    cap_add:
      - SYS_CHROOT
    deploy:
      resources:
        limits:
          cpus: 8
        reservations:
          cpus: 4

  agent:
    build:
      context: .
      dockerfile: images/Containerfile.agent
    image: 'localhost/jenkins-agent:latest'
    container_name: jenkins-agent-service
    hostname: 'jenkins-agent'
    restart: always
    privileged: true
    user: root
    tty: true
    devices:
      - "/dev/tty:/dev/tty"
    expose:
      - 22
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      JAVA_OPTS: ${SELFHOSTED_JENKINS_AGENT_JAVA_OPTS}
      JENKINS_AGENT_SSH_PUBKEY: selfhosted_ci_agent_pubkey
      TZ: ${SELFHOSTED_TZ}
    secrets:
      - source: host_ssh_key
        target: /home/jenkins/.ssh/authorized_keys
    labels:
      - "io.containers.autoupdate=registry"
      - "com.infra.service=ci"
    cap_add:
      - SYS_CHROOT
    deploy:
      resources:
        limits:
          cpus: 10
        reservations:
          cpus: 10

secrets:
  host_ssh_key:
    file: ~/.ssh/jenkins_agent_key.pub

volumes:
  ci_app_data:
    name: ci_app_data
    labels:
      backup: 'true'
