services:
  haproxy:
    build:
      context: .
      dockerfile: Containerfile
    image: localhost/haproxy:latest
    container_name: haproxy-web-service
    hostname: 'haproxy'
    restart: unless-stopped
    ports:
      - '80:80'
      - '443:443'
    environment:
      TZ: ${SELFHOSTED_TZ}
    volumes:
      - ./conf:/var/lib/haproxy:ro
      - /var/run/haproxy:/var/run/haproxy
      - "${SELFHOSTED_HAPROXY_EXTERNAL_CERTS_DIR:?SELFHOSTED_HAPROXY_EXTERNAL_CERTS_DIR is required}:/var/lib/haproxy/certs:ro"
    command: haproxy -f haproxy.cfg -f backend
    labels:
      - "io.containers.autoupdate=local"
      - "com.infra.service=haproxy"

  dataplane-api:
    image: localhost/haproxy:latest
    container_name: haproxy-dataplane-api
    hostname: 'haproxy-dataplane-api'
    restart: unless-stopped
    depends_on:
      haproxy:
        condition: service_started
    pid: service:haproxy
    working_dir: /var/lib/haproxy
    ports:
      - '127.0.0.1:5555:5555'
    environment:
      TZ: ${SELFHOSTED_TZ}
    volumes:
      - ./conf:/var/lib/haproxy
      - "${SELFHOSTED_HAPROXY_EXTERNAL_CERTS_DIR:?SELFHOSTED_HAPROXY_EXTERNAL_CERTS_DIR is required}:/var/lib/haproxy/certs:ro"
    command: /usr/local/bin/run-dataplaneapi.sh
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://127.0.0.1:5555/v3/info"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    labels:
      - "io.containers.autoupdate=local"
      - "com.infra.service=haproxy-dataplane-api"
