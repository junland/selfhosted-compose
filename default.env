SELFHOSTED_TZ="US/Central"
SELFHOSTED_HAPROXY_EXTERNAL_CERTS_DIR="/etc/ssl/certs"
SELFHOSTED_HOARDER_VERSION="release"
SELFHOSTED_HOARDER_NEXTAUTH_SECRET="ChangeMe!"
SELFHOSTED_HOARDER_MEILI_MASTER_KEY="ChangeMe!"
SELFHOSTED_HOARDER_NEXTAUTH_URL="http://hoarder.selfhosted.com"
SELFHOSTED_HOARDER_DISABLE_SIGNUPS="true"
SELFHOSTED_HOARDER_CRAWLER_VIDEO_DOWNLOAD="false"
SELFHOSTED_HOARDER_CRAWLER_VIDEO_DOWNLOAD_MAX_SIZE="5512"
SELFHOSTED_HOARDER_CRAWLER_NUM_WORKERS="4"
SELFHOSTED_HOARDER_BROWSER_WEB_URL="http://chrome:9222"
SELFHOSTED_HOARDER_DATA_DIR="/data"
SELFHOSTED_HOARDER_INFERENCE_JOB_TIMEOUT_SEC="300"
SELFHOSTED_HOARDER_INFERENCE_TEXT_MODEL="qwen:7b"
SELFHOSTED_HOARDER_MEILI_ADDR="http://meilisearch:7700"
SELFHOSTED_HOARDER_MEILI_NO_ANALYTICS="true"
SELFHOSTED_HOARDER_NODE_NO_WARNINGS="1"
SELFHOSTED_HOARDER_OLLAMA_BASE_URL="http://ollama-app-service:11434"
SELFHOSTED_HOARDER_OLLAMA_KEEP_ALIVE="15m"
SELFHOSTED_TAVERN_OLLAMA_KEEP_ALIVE="45h"
SELFHOSTED_OLLAMA_KEEP_ALIVE="30m"
SELFHOSTED_OLLAMA_GIN_MODE="release"
SELFHOSTED_JELLYFIN_PUBLISHED_SERVICE_URL="https://jellyfin.selfhosted.com"
SELFHOSTED_JELLYFIN_PRIMARY_MEDIA_HOST_DIR="/mnt/primary"
SELFHOSTED_JELLYFIN_SECONDARY_MEDIA_HOST_DIR="/mnt/secondary"
SELFHOSTED_DOCKER_HOST="unix:///var/run/docker.sock"
SELFHOSTED_JENKINS_JAVA_OPTS="-Xms2G -Xmx4G -XX:MaxMetaspaceSize=512m -XX:+UseStringDeduplication -XX:+UseParallelGC -XX:+AlwaysPreTouch"
SELFHOSTED_JENKINS_AGENT_JAVA_OPTS="-Xms2G -Xmx4G -XX:MaxMetaspaceSize=512m -XX:+UseStringDeduplication -XX:+UseParallelGC -XX:+AlwaysPreTouch"
